<?xml version="1.0" encoding="UTF-8"?>
<!--
  LocalKey Custom Installer UI
  Replaces WixUI_FeatureTree so we can customise the ProgressDlg
  to add an inline Show / Hide Logs panel.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
<Fragment>
<UI Id="LocalKeyUI">
  <UIRef Id="WixUI_Common" />

  <!-- ═══ Text styles ═══════════════════════════════════════════════════════ -->
  <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
  <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
  <TextStyle Id="WixUI_Font_Title"  FaceName="Tahoma" Size="9" Bold="yes" />

  <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

  <!-- ═══ Error / system dialogs (kept from WixUI library) ════════════════ -->
  <DialogRef Id="ErrorDlg"           />
  <DialogRef Id="FatalError"         />
  <DialogRef Id="FilesInUse"         />
  <DialogRef Id="MsiRMFilesInUse"    />
  <DialogRef Id="PrepareDlg"         />
  <DialogRef Id="ResumeDlg"          />
  <DialogRef Id="UserExit"           />

  <!-- ═══ InstallUISequence ════════════════════════════════════════════════ -->
  <InstallUISequence>
    <Show Dialog="VmWelcomeDlg"       After="PrepareDlg"     >NOT Installed</Show>
    <Show Dialog="VmLicenseDlg"       After="VmWelcomeDlg"     >NOT Installed</Show>
    <Show Dialog="VmFeaturesDlg"      After="VmLicenseDlg"     >NOT Installed</Show>
    <Show Dialog="VmVerifyReadyDlg"   After="VmFeaturesDlg"    >NOT Installed</Show>
    <Show Dialog="VmProgressDlg"    After="VmVerifyReadyDlg" />
    <Show Dialog="VmExitDlg"        After="VmProgressDlg"  />
  </InstallUISequence>

  <!-- ═══ Navigation events ════════════════════════════════════════════════ -->

  <!-- VmWelcomeDlg -->
  <Publish Dialog="VmWelcomeDlg"     Control="Next"   Event="NewDialog"   Value="VmLicenseDlg"     >1</Publish>
  <Publish Dialog="VmWelcomeDlg"     Control="Cancel" Event="SpawnDialog" Value="VmCancelDlg"      >1</Publish>

  <!-- VmLicenseDlg -->
  <Publish Dialog="VmLicenseDlg"     Control="Back"   Event="NewDialog"   Value="VmWelcomeDlg"     >1</Publish>
  <Publish Dialog="VmLicenseDlg"     Control="Next"   Event="NewDialog"   Value="VmFeaturesDlg"    >LicenseAccepted = "1"</Publish>
  <Publish Dialog="VmLicenseDlg"     Control="Cancel" Event="SpawnDialog" Value="VmCancelDlg"      >1</Publish>

  <!-- VmFeaturesDlg -->
  <Publish Dialog="VmFeaturesDlg"    Control="Back"   Event="NewDialog"   Value="VmLicenseDlg"     >1</Publish>
  <Publish Dialog="VmFeaturesDlg"    Control="Next"   Event="NewDialog"   Value="VmVerifyReadyDlg" >1</Publish>
  <Publish Dialog="VmFeaturesDlg"    Control="Cancel" Event="SpawnDialog" Value="VmCancelDlg"      >1</Publish>

  <!-- VmVerifyReadyDlg -->
  <Publish Dialog="VmVerifyReadyDlg" Control="Back"   Event="NewDialog"   Value="VmFeaturesDlg"    >1</Publish>
  <Publish Dialog="VmVerifyReadyDlg" Control="Install" Event="EndDialog"  Value="Return"         >1</Publish>
  <Publish Dialog="VmVerifyReadyDlg" Control="Cancel" Event="SpawnDialog" Value="VmCancelDlg"      >1</Publish>

  <!-- VmProgressDlg — Show Logs button -->
  <Publish Dialog="VmProgressDlg"  Control="ShowLogsBt"
           Property="SHOW_LOGS" Value="1">1</Publish>
  <Publish Dialog="VmProgressDlg"  Control="ShowLogsBt"
           Event="DoAction" Value="CA_ReadLog">1</Publish>
  <Publish Dialog="VmProgressDlg"  Control="HideLogsBt"
           Property="SHOW_LOGS" Value="{}">1</Publish>
  <Publish Dialog="VmProgressDlg"  Control="Cancel"
           Event="SpawnDialog" Value="VmCancelDlg">1</Publish>

  <!-- VmExitDlg — View Log button opens Notepad -->
  <Publish Dialog="VmExitDlg"      Control="ViewLogBt"
           Event="DoAction" Value="CA_OpenLog">1</Publish>
  <Publish Dialog="VmExitDlg"      Control="Finish"
           Event="EndDialog" Value="Return">1</Publish>

  <!-- VmCancelDlg -->
  <Publish Dialog="VmCancelDlg"      Control="Return" Event="EndDialog" Value="Return">1</Publish>
  <Publish Dialog="VmCancelDlg"      Control="Exit"   Event="EndDialog" Value="Exit">1</Publish>

</UI>

<!-- ═══════════════════════════════════════════════════════════════════════════
     DIALOGS
════════════════════════════════════════════════════════════════════════════ -->

<!-- ── VmWelcomeDlg ─────────────────────────────────────────────────────────── -->
<UI>
<Dialog Id="VmWelcomeDlg" Width="370" Height="270" Title="LocalKey Setup">
  <Control Id="Bmp"         Type="Bitmap"     X="0"   Y="0"   Width="164" Height="270" TabSkip="no" Text="WixUI_Bmp_Dialog" />
  <Control Id="BottomLine"  Type="Line"       X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"       X="135" Y="20"  Width="220" Height="60" Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Bigger}Welcome to the LocalKey Setup Wizard</Text>
  </Control>
  <Control Id="Desc"        Type="Text"       X="135" Y="80"  Width="220" Height="80" Transparent="yes" NoPrefix="yes">
    <Text>This wizard will install LocalKey on your computer. Click Next to continue.</Text>
  </Control>
  <Control Id="Next"        Type="PushButton" X="236" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Next >" />
  <Control Id="Cancel"      Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes"  Text="Cancel" />
  <Control Id="Back"        Type="PushButton" X="180" Y="243" Width="56"  Height="17" Disabled="yes" Text="&lt; &amp;Back" />
</Dialog>

<!-- ── VmLicenseDlg ────────────────────────────────────────────────────────── -->
<Dialog Id="VmLicenseDlg" Width="370" Height="270" Title="LocalKey Setup — License Agreement">
  <Control Id="BannerBmp"   Type="Bitmap"     X="0"   Y="0"   Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
  <Control Id="BannerLine"  Type="Line"       X="0"   Y="44"  Width="370" Height="0" />
  <Control Id="BottomLine"  Type="Line"       X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"       X="15"  Y="6"   Width="200" Height="15" Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Title}End-User License Agreement</Text>
  </Control>
  <Control Id="Desc"        Type="Text"       X="25"  Y="23"  Width="320" Height="15" Transparent="yes" NoPrefix="yes">
    <Text>Please read the following license agreement carefully.</Text>
  </Control>
  <!-- ScrollableText reads RTF content from WixUI_LicenseText property -->
  <Control Id="LicText"     Type="ScrollableText" X="20" Y="45" Width="330" Height="155" Sunken="yes" TabSkip="no" Text="[WixUI_LicenseText]" />
  <Control Id="Accept"      Type="CheckBox"   X="20"  Y="206" Width="290" Height="15" Property="LicenseAccepted" CheckBoxValue="1" Text="I accept the terms in the License Agreement" />
  <Control Id="Back"        Type="PushButton" X="180" Y="243" Width="56"  Height="17" Text="&lt; &amp;Back" />
  <Control Id="Next"        Type="PushButton" X="236" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Next >">
    <Condition Action="disable">LicenseAccepted &lt;&gt; "1"</Condition>
    <Condition Action="enable">LicenseAccepted = "1"</Condition>
  </Control>
  <Control Id="Cancel"      Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes"  Text="Cancel" />
</Dialog>

<!-- ── VmFeaturesDlg (Desktop Shortcut checkbox) ────────────────────────────── -->
<Dialog Id="VmFeaturesDlg" Width="370" Height="270" Title="LocalKey Setup — Options">
  <Control Id="BannerBmp"   Type="Bitmap"     X="0"   Y="0"   Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
  <Control Id="BannerLine"  Type="Line"       X="0"   Y="44"  Width="370" Height="0" />
  <Control Id="BottomLine"  Type="Line"       X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"       X="15"  Y="6"   Width="200" Height="15" Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Title}Installation Options</Text>
  </Control>
  <Control Id="Desc"        Type="Text"       X="25"  Y="23"  Width="320" Height="15" Transparent="yes" NoPrefix="yes">
    <Text>Select optional features to install.</Text>
  </Control>
  <Control Id="FeatureTree" Type="SelectionTree" X="25" Y="55" Width="320" Height="155" Property="WIXUI_INSTALLDIR" Sunken="yes" TabSkip="no" Text="{120}{70}{70}" />
  <Control Id="Back"        Type="PushButton" X="180" Y="243" Width="56"  Height="17" Text="&lt; &amp;Back" />
  <Control Id="Next"        Type="PushButton" X="236" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Next >" />
  <Control Id="Cancel"      Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes"  Text="Cancel" />
</Dialog>

<!-- ── VmVerifyReadyDlg ─────────────────────────────────────────────────────── -->
<Dialog Id="VmVerifyReadyDlg" Width="370" Height="270" Title="LocalKey Setup — Ready to Install">
  <Control Id="BannerBmp"   Type="Bitmap"     X="0"   Y="0"   Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
  <Control Id="BannerLine"  Type="Line"       X="0"   Y="44"  Width="370" Height="0" />
  <Control Id="BottomLine"  Type="Line"       X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"       X="15"  Y="6"   Width="200" Height="15" Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Title}Ready to Install</Text>
  </Control>
  <Control Id="Desc"        Type="Text"       X="25"  Y="23"  Width="320" Height="40" Transparent="yes" NoPrefix="yes">
    <Text>Click Install to begin. LocalKey will be installed to C:\LocalKey.</Text>
  </Control>
  <Control Id="Back"        Type="PushButton" X="180" Y="243" Width="56"  Height="17" Text="&lt; &amp;Back" />
  <Control Id="Install"     Type="PushButton" X="236" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Install" />
  <Control Id="Cancel"      Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes"  Text="Cancel" />
</Dialog>

<!-- ── VmProgressDlg ── custom with Show / Hide Logs ─────────────────────── -->
<Dialog Id="VmProgressDlg" Width="370" Height="270" Title="LocalKey Setup — Installing">
  <Control Id="BannerBmp"   Type="Bitmap"       X="0"   Y="0"   Width="370" Height="44"  TabSkip="no" Text="WixUI_Bmp_Banner" />
  <Control Id="BannerLine"  Type="Line"         X="0"   Y="44"  Width="370" Height="0" />
  <Control Id="BottomLine"  Type="Line"         X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"         X="15"  Y="6"   Width="200" Height="15"  Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Title}Installing LocalKey</Text>
  </Control>
  <Control Id="Desc"        Type="Text"         X="25"  Y="23"  Width="320" Height="15"  Transparent="yes" NoPrefix="yes">
    <Text>Please wait while the Setup Wizard installs LocalKey.</Text>
  </Control>

  <!-- Status label + progress bar -->
  <Control Id="StatusLabel" Type="Text"         X="20"  Y="55"  Width="50"  Height="10"  Transparent="yes" Text="Status:" />
  <Control Id="ProgressBar" Type="ProgressBar"  X="20"  Y="68"  Width="330" Height="15"  ProgressBlocks="yes" Text="Progress done" />
  <Control Id="ActionText"  Type="Text"         X="20"  Y="88"  Width="250" Height="10"  Transparent="yes" Text="[ActionText]" />

  <!-- Show Logs button — visible when log is hidden -->
  <Control Id="ShowLogsBt"  Type="PushButton"   X="280" Y="85"  Width="70"  Height="14"  Text="Show Logs ▼">
    <Condition Action="show">NOT SHOW_LOGS = "1"</Condition>
    <Condition Action="hide">SHOW_LOGS = "1"</Condition>
  </Control>

  <!-- Hide Logs button — visible when log is shown -->
  <Control Id="HideLogsBt"  Type="PushButton"   X="280" Y="85"  Width="70"  Height="14"  Text="Hide Logs ▲" Hidden="yes">
    <Condition Action="show">SHOW_LOGS = "1"</Condition>
    <Condition Action="hide">NOT SHOW_LOGS = "1"</Condition>
  </Control>

  <!-- Inline log panel — same style as the license text box -->
  <Control Id="LogText"     Type="ScrollableText" X="20" Y="103" Width="330" Height="120" Sunken="yes" TabSkip="no"
           Text="[LOCALKEY_LOG_CONTENT]" Hidden="yes">
    <Condition Action="show">SHOW_LOGS = "1"</Condition>
    <Condition Action="hide">NOT SHOW_LOGS = "1"</Condition>
  </Control>

  <Control Id="Back"        Type="PushButton"   X="180" Y="243" Width="56"  Height="17"  Disabled="yes" Text="&lt; &amp;Back" />
  <Control Id="Next"        Type="PushButton"   X="236" Y="243" Width="56"  Height="17"  Disabled="yes" Text="&amp;Next >" />
  <Control Id="Cancel"      Type="PushButton"   X="304" Y="243" Width="56"  Height="17"  Cancel="yes"   Text="Cancel" />
</Dialog>

<!-- ── VmExitDlg ──────────────────────────────────────────────────────────── -->
<Dialog Id="VmExitDlg" Width="370" Height="270" Title="LocalKey Setup — Completed">
  <Control Id="Bmp"         Type="Bitmap"     X="0"   Y="0"   Width="164" Height="270" TabSkip="no" Text="WixUI_Bmp_Dialog" />
  <Control Id="BottomLine"  Type="Line"       X="0"   Y="234" Width="370" Height="0" />
  <Control Id="Title"       Type="Text"       X="135" Y="20"  Width="220" Height="60" Transparent="yes" NoPrefix="yes">
    <Text>{\WixUI_Font_Bigger}Completed the LocalKey Setup Wizard</Text>
  </Control>
  <Control Id="Desc"        Type="Text"       X="135" Y="85"  Width="220" Height="60" Transparent="yes" NoPrefix="yes">
    <Text>Click Finish to exit the Setup Wizard. LocalKey is building in the background — check the log for details.</Text>
  </Control>
  <Control Id="ViewLogBt"   Type="PushButton" X="135" Y="155" Width="90"  Height="17" Text="View Install Log" />
  <Control Id="Finish"      Type="PushButton" X="236" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Finish" />
  <Control Id="Cancel"      Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes"  Text="Cancel" />
  <Control Id="Back"        Type="PushButton" X="180" Y="243" Width="56"  Height="17" Disabled="yes" Text="&lt; &amp;Back" />
</Dialog>

<!-- ── VmCancelDlg ─────────────────────────────────────────────────────────── -->
<Dialog Id="VmCancelDlg" Width="260" Height="85" Title="LocalKey Setup" NoMinimize="yes">
  <Control Id="Question"    Type="Text"       X="48"  Y="15"  Width="194" Height="30" Text="Are you sure you want to cancel LocalKey installation?" />
  <Control Id="Return"      Type="PushButton" X="100" Y="57"  Width="56"  Height="17" Default="yes" Text="&amp;Return" />
  <Control Id="Exit"        Type="PushButton" X="164" Y="57"  Width="56"  Height="17" Cancel="yes"  Text="E&amp;xit" />
</Dialog>

</UI>
</Fragment>
</Wix>
